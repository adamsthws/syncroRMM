#Requires -RunAsAdministrator
Import-Module $env:SyncroModule

# =============================================================================
# Deploys RustDesk to a client machine
#  - Configures various options (auto-update etc)
#  - Sets a unique permanent password
#  - Writes connection details (ID & PW) to Syncro asset fields.
#
#    Compatability: Windows-x64 only
#    To-do: Add connection string to Sycnro for one-click connection
#           URL structure: rustdesk://connection/new/<rustdesk-ID>?password=<rustdesk-pw>
#           *Hijack the "ScreenConnect" asset field to store the connection URL?
# =============================================================================


# --- SCRIPT CONFIGURATION ---
$rustDeskServiceName = "RustDesk"
$rustDeskExe         = "C:\Program Files\RustDesk\rustdesk.exe"
$tempDir             = "C:\temp"
$apiUrl              = "https://api.github.com/repos/rustdesk/rustdesk/releases/latest"
$timeoutSeconds      = 120

# --- RUSTDESK OPTIONS ---
$rustDeskOptions = @(
    @{ Key = "theme";                            Value = "dark"               },
    @{ Key = "access-mode";                      Value = "full"               },
    @{ Key = "allow-remote-config-modification"; Value = "Y"                 },
    @{ Key = "approve-mode";                     Value = "password-click"     },
    @{ Key = "verification-method";              Value = "use-both-passwords" },
    @{ Key = "temporary-password-length";        Value = "10"                 },
    @{ Key = "allow-auto-update";                Value = "Y"                  }
)

# --- Helper: Write a timestamped log line ---
function Write-Log {
    param([string]$Message, [ValidateSet("INFO","WARN","ERROR")][string]$Level = "INFO")
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    Write-Host "[$timestamp] [$Level] $Message"
}

# --- Helper: Generate a CVCVC pronounceable word, first letter capitalised ---
function New-PronouncableWord {
    $consonants = 'b','c','d','f','g','h','j','k','l','m','n','p','r','s','t','v','w','x','z'
    $vowels     = 'a','e','i','o','u'

    $word  = ($consonants | Get-Random).ToUpper()
    $word += ($vowels     | Get-Random)
    $word += ($consonants | Get-Random)
    $word += ($vowels     | Get-Random)
    $word += ($consonants | Get-Random)

    return $word
}

# --- Helper: Generate full password  e.g. "Batel-Miron-Depus-4" ---
function New-RustDeskPassword {
    $w1     = New-PronouncableWord
    $w2     = New-PronouncableWord
    $w3     = New-PronouncableWord
    $digit  = Get-Random -Minimum 0 -Maximum 9
    return "$w1-$w2-$w3-$digit"
}

# --- Helper: Get installed RustDesk version from registry ---
function Get-InstalledRustDeskVersion {
    try {
        $regPath = "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\RustDesk"
        if (Test-Path $regPath) {
            return (Get-ItemProperty $regPath -ErrorAction Stop).Version
        }
    } catch { }
    # If the registry key doesn't exist or can't be read, assume not installed
    return $null
}

# --- Helper: Get latest RustDesk release info from GitHub ---
function Get-LatestRustDeskRelease {
    $headers  = @{ "User-Agent" = "RustDesk-Deploy-Script" }
    $release  = Invoke-RestMethod -Uri $apiUrl -Headers $headers -ErrorAction Stop

    # Target the 64-bit Windows MSI (preferred for RMM deployment - clean uninstall,
    # supports shortcut/printer suppression via msiexec properties)
    $asset = $release.assets | Where-Object {
        $_.name -match "x86_64\.msi$"
    } | Select-Object -First 1

    if (-not $asset) {
        throw "Could not find a Windows x86_64 MSI asset in the latest GitHub release."
    }

    return @{
        Version     = $release.tag_name.TrimStart("v")
        DownloadUrl = $asset.browser_download_url
        FileName    = $asset.name
    }
}

# --- Helper: Wait for a service to reach a desired status ---
function Wait-ForService {
    param(
        [string]$ServiceName,
        [string]$DesiredStatus = "Running"
    )
    $elapsed = 0
    while ($elapsed -lt $timeoutSeconds) {
        $svc = Get-Service -Name $ServiceName -ErrorAction SilentlyContinue
        if ($svc -and $svc.Status -eq $DesiredStatus) { return $true }
        Start-Sleep -Seconds 3
        $elapsed += 3
    }
    return $false
}

# --- Helper: Start service if not already running, then wait for Running state ---
function Invoke-EnsureServiceRunning {
    param(
        [string]$ServiceName,
        [switch]$AlwaysStart
    )
    $svc = Get-Service -Name $ServiceName -ErrorAction SilentlyContinue
    # If the service doesn't exist at all, register it
    if (-not $svc) {
        Write-Log "Service '$ServiceName' is not registered. Re-registering via --install-service..."
        $installDir = Split-Path $rustDeskExe -Parent
        Start-Process -FilePath $rustDeskExe -ArgumentList "--install-service" -WorkingDirectory $installDir -ErrorAction Stop
        Start-Sleep -Seconds 5
        $AlwaysStart = $true
    }
    # If the service exists but is not running, start it
    if ($AlwaysStart -or (Get-Service -Name $ServiceName -ErrorAction Stop).Status -ne "Running") {
        Start-Service -Name $ServiceName -ErrorAction Stop
        $started = Wait-ForService -ServiceName $ServiceName -DesiredStatus "Running"
        if (-not $started) { throw "Service '$ServiceName' did not reach Running state within timeout." }
    }
}

# --- Helper: Set a single RustDesk option (via --option) ---
function Set-RustDeskOption {
    param(
        [string]$Key,
        [string]$Value
    )
    $installDir = Split-Path $rustDeskExe -Parent
    $proc = Start-Process -FilePath $rustDeskExe -ArgumentList "--option `"$Key`" `"$Value`"" -WorkingDirectory $installDir -Wait -PassThru -ErrorAction Stop
    if ($proc.ExitCode -ne 0) {
        throw "rustdesk.exe --option '$Key' exited with code $($proc.ExitCode)."
    }
}

# --- Helper: Retrieve the RustDesk ID via --get-id ---
function Get-RustDeskID {
    param(
        [string]$RustDeskExe
    )

    $installDir = Split-Path $RustDeskExe -Parent
    $elapsed    = 0

    while ($elapsed -lt $timeoutSeconds) {
        try {
            # Must run from the install directory for --get-id to output correctly
            Push-Location $installDir
            $id = (.\rustdesk.exe --get-id | Out-String).Trim()
            Pop-Location

            # A valid RustDesk ID is numeric, typically 9-10 digits
            if ($id -and $id -match '^\d{6,}$') {
                return $id
            }
        } catch {
            try { Pop-Location } catch { }
        }

        Start-Sleep -Seconds 3
        $elapsed += 3
    }

    return $null
}

# =============================================================================
# MAIN
# =============================================================================

# -----------------------------------------------------------------------------
# STEP 1 - Check if RustDesk is installed
# -----------------------------------------------------------------------------

$installedVersion = Get-InstalledRustDeskVersion
if ($installedVersion) {
    Write-Log "RustDesk $installedVersion is already installed. Skipping installation."
    $skipInstall = $true
} else {
    Write-Log "RustDesk is not installed. Proceeding with fresh install."
    $skipInstall = $false
}

# -----------------------------------------------------------------------------
# STEP 2 - Download and install if needed
# -----------------------------------------------------------------------------
if (-not $skipInstall) {
    try {
        $latest = Get-LatestRustDeskRelease
    } catch {
        Write-Log "Failed to retrieve latest release from GitHub: $_" -Level ERROR
        exit 1
    }

    try {
        if (-not (Test-Path $tempDir)) {
            New-Item -ItemType Directory -Force -Path $tempDir | Out-Null
        }

        $installerPath = Join-Path $tempDir $latest.FileName
        Write-Log "Installing RustDesk $($latest.Version) from $($latest.DownloadUrl)."
        Invoke-WebRequest -Uri $latest.DownloadUrl -OutFile $installerPath -UseBasicParsing -ErrorAction Stop

        # Install silently with msiexec
        $msiArgs = "/i `"$installerPath`" /quiet /norestart CREATEDESKTOPSHORTCUTS=N CREATESTARTMENUSHORTCUTS=N INSTALLPRINTER=N"
        $proc = Start-Process -FilePath "msiexec.exe" -ArgumentList $msiArgs -Wait -PassThru -ErrorAction Stop
        if ($proc.ExitCode -ne 0) {
            throw "msiexec exited with code $($proc.ExitCode)."
        }

    } catch {
        Write-Log "Installation failed: $_" -Level ERROR
        exit 1
    } finally {
        if (Test-Path $installerPath) {
            Remove-Item $installerPath -Force -ErrorAction SilentlyContinue
        }
    }

    # Pause to allow the MSI to finish registering the service.
    Start-Sleep -Seconds 5

    # Wait for service to appear and start
    $started = Wait-ForService -ServiceName $rustDeskServiceName -DesiredStatus "Running"
    if (-not $started) {
        Write-Log "RustDesk service did not reach Running state within timeout." -Level ERROR
        exit 1
    }
}


# -----------------------------------------------------------------------------
# STEP 3 - Check service is running (required for applying options, setting password etc)
# -----------------------------------------------------------------------------

try {
    Invoke-EnsureServiceRunning -ServiceName $rustDeskServiceName
} catch {
    Write-Log "Failed to ensure RustDesk service is running (required for applying options): $_" -Level ERROR
    exit 1
}

# -----------------------------------------------------------------------------
# STEP 4 - Apply configuration
# -----------------------------------------------------------------------------

try {
    foreach ($opt in $rustDeskOptions) {
        Set-RustDeskOption -Key $opt.Key -Value $opt.Value
    }
} catch {
    Write-Log "Failed to apply RustDesk options: $_" -Level ERROR
    exit 1
}

# -----------------------------------------------------------------------------
# STEP 5 - Set/update password
# -----------------------------------------------------------------------------

# Generate the password
try {
    $password = New-RustDeskPassword
} catch {
    Write-Log "Failed to generate password: $_" -Level ERROR
    exit 1
}

# Set the password
try {
    $installDir = Split-Path $rustDeskExe -Parent
    $proc = Start-Process -FilePath $rustDeskExe -ArgumentList "--password `"$password`"" -WorkingDirectory $installDir -Wait -PassThru -ErrorAction Stop
    if ($proc.ExitCode -ne 0) {
        throw "'rustdesk.exe --password' exited with code $($proc.ExitCode)."
    }
} catch {
    Write-Log "Failed to set RustDesk password: $_" -Level ERROR
    exit 1
}

# -----------------------------------------------------------------------------
# STEP 6 - Retrieve RustDesk ID
# -----------------------------------------------------------------------------

$rustDeskID = Get-RustDeskID -RustDeskExe $rustDeskExe

if (-not $rustDeskID) {
    Write-Log "Could not retrieve RustDesk ID within timeout. The ID may not have been assigned yet." -Level WARN
    Write-Log "Syncro asset fields have not been updated with the RustDesk ID/Password." -Level WARN
    exit 1
}

# -----------------------------------------------------------------------------
# STEP 7 - Update Syncro asset fields
# -----------------------------------------------------------------------------
try {
    Set-Asset-Field -Name "RustDesk ID" -Value $rustDeskID -ErrorAction Stop
    Set-Asset-Field -Name "RustDesk Password" -Value $password -ErrorAction Stop
    ### To-Do ###
    # Writing to the "ScreenConnect GUID" field activates Syncro's built-in remote-session
    # button and activity logging — the mechanism used by the native SC integration.
    #Set-Asset-Field -Name "ScreenConnect GUID" -Value "rustdesk://connect/$rustDeskID" -ErrorAction Stop
    Write-Log "Rustdesk deploy/update finished successfully."
} catch {
    Write-Log "Failed to update Syncro asset fields: $_" -Level WARN
}